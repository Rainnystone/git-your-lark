{
  "name": "git-your-lark",
  "version": "0.3.0",
  "description": "Preview-first Markdown workspace publishing and importing for Lark/Feishu through lark-cli.",
  "type": "module",
  "bin": {
    "gyl": "./dist/gyl.js"
  },
  "files": [
    "dist/gyl.js",
    "dist/scripts/",
    ".codex-plugin/",
    "skills/",
    "docs/examples/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bundle": "node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx scripts/gyl.ts",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "check:package": "node scripts/check-package.mjs"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
