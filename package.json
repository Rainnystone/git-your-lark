{
  "name": "git-your-lark",
  "version": "0.1.0",
  "description": "Preview-first Markdown workspace publishing to Lark/Feishu through lark-cli.",
  "type": "module",
  "bin": {
    "gyl": "./dist/gyl.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx scripts/gyl.ts",
    "validate:plugin": "node scripts/validate-plugin.mjs"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
